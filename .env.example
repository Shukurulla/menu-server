PORT=5321
MONGO_URI=mongodb://localhost:27017/menu
JWT_SECRET=supersecret_change_me_in_production
AES_SECRET=0123456789abcdef0123456789abcdef
FRONTEND_URL=http://localhost:5173
SUPER_ADMIN_EMAIL=admin@menu.app
SUPER_ADMIN_PASSWORD=admin123

# Firebase Cloud Messaging — for restaurant admin web push (new-order alerts).
# Skip these in dev — server will run fine without them, just no push.
# Get values from Firebase Console → Project Settings → Service accounts → Generate new private key.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# IMPORTANT: keep the private key on a single line and escape newlines as \n
FIREBASE_PRIVATE_KEY=
